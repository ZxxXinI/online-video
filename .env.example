NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional Redis cache. Leave empty to disable Redis and use source requests directly.
# Example command equivalent:
# redis-cli -h <server-ip-or-domain> -p 6380 --tls --cacert ca.crt -a <password>
REDIS_HOST=
REDIS_PORT=6380
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=true
REDIS_CA_PATH=ca.crt
# Set to false only when connecting by IP to a TLS server whose certificate does not contain that IP.
REDIS_TLS_REJECT_UNAUTHORIZED=true

# Alternative single URL form. Use rediss:// for TLS.
# REDIS_URL=rediss://username:password@host:6380/0
